#!/bin/sh
# Demeter .deb post-remove: tidy systemd; on purge, delete data + the user.
set -e

SERVICE=demeter
RUN_USER=demeter
DATA_DIR=/var/lib/demeter

case "$1" in
	purge)
		rm -rf "$DATA_DIR"
		if getent passwd "$RUN_USER" >/dev/null 2>&1; then
			deluser --system "$RUN_USER" >/dev/null 2>&1 || userdel "$RUN_USER" >/dev/null 2>&1 || true
		fi
		systemctl daemon-reload >/dev/null 2>&1 || true
		;;
	remove)
		systemctl daemon-reload >/dev/null 2>&1 || true
		;;
esac

exit 0
